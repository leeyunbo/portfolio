graph TD
  SCHED["Daily Scheduler<br/>(매일 오전 7시)"]
  PIPE["Pipeline Orchestrator"]

  subgraph Collect["병렬 데이터 수집 (asyncio.gather)"]
    direction LR
    MKT["Market Collector<br/>(네이버 금융 API)<br/>KOSPI · KOSDAQ · 투자자별 매매"]
    DART["Disclosure Collector<br/>(DART API)<br/>정기 · 주요사항 · 발행 · 지분"]
    NEWS["News Collector<br/>(네이버 뉴스 API)<br/>시장 뉴스 · 종목별 뉴스"]
  end

  subgraph AI["AI 브리핑 생성"]
    direction TB
    SUM["Summarizer"]
    subgraph Provider["AI Provider (Protocol 패턴)"]
      direction LR
      CLAUDE["Claude Provider"]
      GEMINI["Gemini Provider"]
    end
  end

  subgraph Output["저장 & 발송"]
    direction LR
    DB[("SQLite")]
    EMAIL["Email Sender<br/>(SMTP + Retry)"]
    SUB["구독자"]
  end

  SCHED --> PIPE
  PIPE --> Collect
  MKT --> SUM
  DART --> SUM
  NEWS --> SUM
  SUM --> CLAUDE
  SUM --> GEMINI
  AI --> DB
  AI --> EMAIL
  EMAIL --> SUB

  style Collect fill:#172554,stroke:#3b82f6,color:#bfdbfe
  style AI fill:#14332a,stroke:#22c55e,color:#a7f3d0
  style Provider fill:#1a3a2a,stroke:#4ade80,color:#bbf7d0
  style Output fill:#422006,stroke:#f59e0b,color:#fde68a
