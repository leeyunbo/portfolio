---
import { skillGroups } from '../data/portfolio';
---

<section id="skills" class="py-12 px-6">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-lg font-semibold text-zinc-800 dark:text-zinc-100 mb-8">Skills</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {skillGroups.map(group => (
        <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 p-4">
          <h3 class="text-xs font-bold text-zinc-400 dark:text-zinc-500 uppercase tracking-widest mb-3">{group.category}</h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map(item => (
              <span class="rounded-lg bg-zinc-100 dark:bg-zinc-800 px-3 py-1.5 text-sm font-medium text-zinc-700 dark:text-zinc-300">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
