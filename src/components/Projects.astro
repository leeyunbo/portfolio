---
import { workProjects, sideProjects } from '../data/portfolio';
---

<section id="projects" class="py-12 px-6">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-lg font-semibold text-zinc-800 dark:text-zinc-100 mb-8">Projects</h2>

    <!-- Work Projects -->
    <h3 class="text-xs font-bold text-zinc-400 dark:text-zinc-500 uppercase tracking-widest mb-4">실무 프로젝트</h3>
    <div class="grid gap-3 mb-12">
      {workProjects.map((project, i) => (
        <div
          class="group rounded-xl border border-zinc-200 dark:border-zinc-800 p-5 cursor-pointer hover:border-blue-200 dark:hover:border-zinc-700 hover:bg-zinc-50 dark:hover:bg-zinc-900/50 transition-all"
          data-modal-trigger={i}
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <h4 class="text-[15px] font-bold text-zinc-900 dark:text-zinc-50">{project.title}</h4>
                {project.inProgress && (
                  <span class="rounded-full bg-blue-500/10 border border-blue-500/20 px-2 py-0.5 text-xs text-blue-600 dark:text-blue-400 shrink-0">
                    진행 중
                  </span>
                )}
              </div>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-3 leading-relaxed">{project.summary}</p>
              <div class="flex items-center gap-3 flex-wrap">
                <span class="inline-flex items-center gap-1.5 rounded-lg bg-blue-50 dark:bg-blue-500/10 border border-blue-100 dark:border-blue-500/20 px-3 py-1">
                  <span class="w-1.5 h-1.5 rounded-full bg-blue-500 shrink-0"></span>
                  <span class="text-xs font-semibold text-blue-700 dark:text-blue-400">{project.impact}</span>
                </span>
                <div class="flex flex-wrap gap-1.5">
                  {project.tech.map(t => (
                    <span class="rounded-md bg-zinc-100 dark:bg-zinc-800 px-2 py-0.5 text-xs font-mono text-zinc-500 dark:text-zinc-400">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </div>
            <svg class="w-4 h-4 text-zinc-300 dark:text-zinc-600 group-hover:text-zinc-400 dark:group-hover:text-zinc-400 shrink-0 mt-1 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      ))}
    </div>

    <!-- Side Projects -->
    <h3 class="text-xs font-bold text-zinc-400 dark:text-zinc-500 uppercase tracking-widest mb-4">개인 프로젝트</h3>
    <div class="grid gap-4">
      {sideProjects.map(project => (
        <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 p-5 hover:border-zinc-300 dark:hover:border-zinc-700 transition-colors">
          <div class="flex items-start justify-between mb-2">
            <div class="flex items-center gap-2 flex-wrap">
              <h4 class="text-sm font-bold text-zinc-800 dark:text-zinc-100">{project.title}</h4>
              {project.live && (
                <span class="rounded-full bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 text-xs font-medium text-emerald-600 dark:text-emerald-400">
                  운영 중
                </span>
              )}
            </div>
            <div class="flex items-center gap-2 shrink-0 ml-2">
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener"
                  class="text-zinc-400 dark:text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
                  aria-label={`${project.title} 바로가기`}
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener"
                  class="text-zinc-400 dark:text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
                  aria-label={`${project.title} GitHub`}
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                  </svg>
                </a>
              )}
            </div>
          </div>
          <ul class="space-y-1 text-sm text-zinc-500 dark:text-zinc-400 mb-3">
            {project.description.map(item => (
              <li class="flex gap-2">
                <span class="text-zinc-300 dark:text-zinc-600 shrink-0 mt-0.5">—</span>
                <span class="leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
          <div class="flex flex-wrap gap-1.5 mb-3">
            {project.tech.map(t => (
              <span class="rounded-md bg-zinc-100 dark:bg-zinc-800 px-2 py-0.5 text-xs font-mono text-zinc-500 dark:text-zinc-400">
                {t}
              </span>
            ))}
          </div>
          {project.diagram && (
            <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 overflow-hidden bg-white dark:bg-zinc-900 p-3 mt-2">
              <img src={project.diagram} alt={`${project.title} architecture`} class="w-full h-auto block dark:hidden" />
              <img src={project.diagramDark} alt={`${project.title} architecture`} class="w-full h-auto hidden dark:block" />
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Modal -->
<div id="project-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
  <div id="modal-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
  <div class="relative w-full max-w-2xl max-h-[85vh] rounded-2xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 overflow-y-auto shadow-2xl">
    <div class="sticky top-0 flex items-center justify-between px-6 py-4 bg-white dark:bg-zinc-900 border-b border-zinc-100 dark:border-zinc-800">
      <h3 id="modal-title" class="text-base font-bold text-zinc-900 dark:text-zinc-50"></h3>
      <button id="modal-close" class="text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200 transition-colors p-1 -mr-1" aria-label="닫기">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div id="modal-content" class="px-6 py-5"></div>
  </div>
</div>

<!-- Modal data templates -->
{workProjects.map((project, i) => (
  <template data-modal-content={i}>
    <div class="mb-5 rounded-lg bg-blue-50 dark:bg-blue-500/10 border border-blue-100 dark:border-blue-500/20 px-4 py-3">
      <p class="text-xs font-medium text-blue-600 dark:text-blue-400 mb-0.5">핵심 성과</p>
      <p class="text-sm font-bold text-blue-800 dark:text-blue-300">{project.impact}</p>
    </div>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4 leading-relaxed">{project.summary}</p>
    <div class="flex flex-wrap gap-1.5 mb-6">
      {project.tech.map(t => (
        <span class="rounded-md bg-zinc-100 dark:bg-zinc-800 px-2 py-1 text-xs font-mono text-zinc-500 dark:text-zinc-400">
          {t}
        </span>
      ))}
    </div>
    {project.sections.map(s => (
      <div class="mb-5">
        <h4 class="text-xs font-bold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider mb-2">{s.label}</h4>
        <ul class="space-y-1.5 text-sm text-zinc-600 dark:text-zinc-300 leading-relaxed">
          {s.items.map(item => (
            <li class="flex gap-2">
              <span class="text-zinc-300 dark:text-zinc-600 shrink-0 mt-0.5">—</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </template>
))}

<script>
  const modal = document.getElementById('project-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalContent = document.getElementById('modal-content');
  const modalClose = document.getElementById('modal-close');
  const modalBackdrop = document.getElementById('modal-backdrop');

  document.querySelectorAll('[data-modal-trigger]').forEach(card => {
    card.addEventListener('click', () => {
      const idx = card.getAttribute('data-modal-trigger');
      const template = document.querySelector(`[data-modal-content="${idx}"]`) as HTMLTemplateElement;
      const title = card.querySelector('h4')?.textContent || '';

      if (template && modalTitle && modalContent && modal) {
        modalTitle.textContent = title;
        modalContent.innerHTML = template.innerHTML;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  function closeModal() {
    if (modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }
  }

  modalClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
