---
import { careers } from '../data/portfolio';
---

<section id="experience" class="py-12 px-6">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-lg font-semibold text-zinc-800 dark:text-zinc-100 mb-8">Experience</h2>

    <div class="space-y-8">
      {careers.map(career => (
        <div class="relative pl-6 border-l-2 border-zinc-200 dark:border-zinc-800">
          <div class="absolute -left-[5px] top-1.5 w-2.5 h-2.5 rounded-full bg-blue-500 dark:bg-blue-400" />
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1 gap-1">
            <h3 class="text-base font-bold text-zinc-900 dark:text-zinc-50">{career.company}</h3>
            <span class="font-mono text-xs text-zinc-400 dark:text-zinc-500 shrink-0">{career.period}</span>
          </div>
          <p class="text-sm font-medium text-blue-600 dark:text-blue-400 mb-2">{career.role}</p>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">{career.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
